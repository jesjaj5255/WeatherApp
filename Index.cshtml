@model IEnumerable<WeatherData>

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>🌡️ Данные о погоде</h2>
        </div>
        <div class="col-md-4 text-end">
            @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
            {
                <a asp-controller="WeatherData" asp-action="Create" class="btn btn-success">
                    + Добавить запись
                </a>
            }
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Город</th>
                    <th>Температура</th>
                    <th>Влажность</th>
                    <th>Ветер</th>
                    <th>Описание</th>
                    <th>Дата</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.City?.Name</td>
                        <td>
                            <span class="badge bg-info">@item.Temperature°C</span>
                        </td>
                        <td>
                            <span class="badge bg-primary">@item.Humidity%</span>
                        </td>
                        <td>@item.WindSpeed км/ч</td>
                        <td>@item.Description</td>
                        <td>@item.Date.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            <a asp-controller="WeatherData" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">
                                Просмотр
                            </a>
                            @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                            {
                                <a asp-controller="WeatherData" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                    Редакт.
                                </a>
                            }
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-controller="WeatherData" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                    Удал.
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>