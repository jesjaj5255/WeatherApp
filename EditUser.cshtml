@model WeatherApp.Models.User

@{
    ViewData["Title"] = "Редактировать пользователя";
}

<h2>Редактировать: @Model.Email</h2>

<form method="post" class="mt-4">
    <div class="mb-3">
        <label>Email</label>
        <input type="text" class="form-control" value="@Model.Email" disabled>
    </div>

    <div class="mb-3">
        <label>Полное имя</label>
        <input type="text" class="form-control" value="@Model.FullName" disabled>
    </div>

    <div class="mb-3">
        <label>Роли</label>
        <div>
            @foreach (var role in ViewBag.AllRoles)
            {
                <div class="form-check">
                    <input type="checkbox" class="form-check-input" name="selectedRoles" value="@role.Name"
                           id="role_@role.Id" @(ViewBag.UserRoles.Contains(role.Name) ? "checked" : "")>
                    <label class="form-check-label" for="role_@role.Id">@role.Name</label>
                </div>
            }
        </div>
    </div>

    <a href="/Admin/Users" class="btn btn-secondary">Отмена</a>
    <button type="submit" class="btn btn-primary">Сохранить</button>
</form>