@model User
@{
    ViewData["Title"] = "Удалить пользователя";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="alert alert-danger" role="alert">
                <h4 class="alert-heading">⚠️ Подтверждение удаления</h4>
                <p>Вы уверены, что хотите удалить пользователя? Это действие необратимо!</p>
                <hr>
                <p class="mb-1"><strong>📧 Email:</strong> @Model.Email</p>
                <p class="mb-0"><strong>👤 Имя:</strong> @(Model.FullName ?? "Не указано")</p>
            </div>

            <form method="post" class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">🗑️ Удалить</button>
                <a href="@Url.Action("Users")" class="btn btn-secondary">Отмена</a>
            </form>
        </div>
    </div>
</div>