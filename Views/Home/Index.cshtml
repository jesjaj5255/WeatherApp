@model IEnumerable<WeatherApp.Models.City>

@{
    ViewData["Title"] = "Home";
}

<div class="row mb-4">
    <div class="col-md-8">
        <h1>🌤️ WeatherApp</h1>
        <p class="lead">Explore weather records for cities around the world.</p>
    </div>
    <div class="col-md-4 text-end">
        <a asp-controller="WeatherData" asp-action="Index" class="btn btn-primary">View Weather Records</a>
    </div>
</div>

<div class="row mb-3">
    <div class="col-md-12">
        <form method="get" class="d-flex gap-2">
            <input type="text" name="country" value="@ViewBag.FilterCountry" class="form-control" placeholder="Filter by country..." />
            <select name="sortBy" class="form-select" style="max-width:180px;">
                <option value="name" selected="@(ViewBag.SortBy == "name")">Name A-Z</option>
                <option value="name_desc" selected="@(ViewBag.SortBy == "name_desc")">Name Z-A</option>
                <option value="country" selected="@(ViewBag.SortBy == "country")">Country</option>
            </select>
            <button type="submit" class="btn btn-outline-secondary">Search</button>
            <a asp-action="Index" class="btn btn-outline-danger">Clear</a>
        </form>
    </div>
</div>

<div class="row row-cols-1 row-cols-md-3 g-4 mb-4">
    @foreach (var city in Model)
    {
        <div class="col">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">📍 @city.Name</h5>
                    <h6 class="card-subtitle mb-2 text-muted">@city.Country</h6>
                    @if (!string.IsNullOrEmpty(city.Description))
                    {
                        <p class="card-text small">@city.Description</p>
                    }
                </div>
                <div class="card-footer d-flex gap-2">
                    <a asp-controller="Cities" asp-action="Details" asp-route-id="@city.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-controller="WeatherData" asp-action="Index" asp-route-cityId="@city.Id" class="btn btn-sm btn-outline-primary">Weather</a>
                </div>
            </div>
        </div>
    }
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav>
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@i"
                       asp-route-sortBy="@ViewBag.SortBy"
                       asp-route-country="@ViewBag.FilterCountry">@i</a>
                </li>
            }
        </ul>
    </nav>
}

<div class="row mt-4">
    <div class="col-md-12">
        <div class="card bg-light">
            <div class="card-body small text-muted">
                <strong>Session info:</strong>
                Page visits this session: <span class="badge bg-secondary">@ViewBag.VisitCount</span> |
                First visit: @ViewBag.FirstVisit |
                Last visit (cookie): @ViewBag.LastVisit
            </div>
        </div>
    </div>
</div>
