@model List<(WeatherApp.Models.User User, IList<string> Roles)>
@{
    ViewData["Title"] = "Пользователи";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title mb-0">👥 Пользователи системы</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Панель управления</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center py-4">
        <h5>Пользователей не найдено</h5>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>📧 Email</th>
                    <th>👤 Полное имя</th>
                    <th>🔑 Роли</th>
                    <th>📅 Дата регистрации</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var (user, roles) in Model)
                {
                    <tr>
                        <td>@user.Email</td>
                        <td>@(user.FullName ?? "—")</td>
                        <td>
                            @foreach (var role in roles)
                            {
                                <span class="badge text-white me-1 @(role == "Admin" ? "role-badge-admin" : role == "Manager" ? "role-badge-manager" : "role-badge-user")">
                                    @role
                                </span>
                            }
                            @if (!roles.Any())
                            {
                                <span class="text-muted small">Нет ролей</span>
                            }
                        </td>
                        <td class="small">@user.RegistrationDate.ToString("dd.MM.yyyy")</td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a asp-action="EditUser" asp-route-id="@user.Id"
                                   class="btn btn-outline-secondary">✏️ Роли</a>
                                <a asp-action="DeleteUser" asp-route-id="@user.Id"
                                   class="btn btn-outline-danger">🗑️</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if ((int)ViewBag.TotalPages > 1)
    {
        <nav aria-label="Навигация по страницам" class="mt-3">
            <ul class="pagination justify-content-center">
                <li class="page-item @((int)ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Users"
                       asp-route-page="@((int)ViewBag.CurrentPage - 1)">‹ Назад</a>
                </li>
                @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == (int)ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Users" asp-route-page="@i">@i</a>
                    </li>
                }
                <li class="page-item @((int)ViewBag.CurrentPage == (int)ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Users"
                       asp-route-page="@((int)ViewBag.CurrentPage + 1)">Вперёд ›</a>
                </li>
            </ul>
        </nav>
    }
}
