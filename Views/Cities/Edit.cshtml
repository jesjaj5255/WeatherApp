@model WeatherApp.Models.City
@{
    ViewData["Title"] = "Редактировать город";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <h1 class="page-title">✏️ Редактировать город</h1>

        <div class="form-card">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <input asp-for="Id" type="hidden" />
                <input asp-for="CreatedDate" type="hidden" />

                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Country" class="form-label"></label>
                    <input asp-for="Country" class="form-control" />
                    <span asp-validation-for="Country" class="text-danger small"></span>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-sm-6">
                        <label asp-for="Latitude" class="form-label"></label>
                        <input asp-for="Latitude" class="form-control" type="number" step="0.0001" />
                        <span asp-validation-for="Latitude" class="text-danger small"></span>
                    </div>
                    <div class="col-sm-6">
                        <label asp-for="Longitude" class="form-label"></label>
                        <input asp-for="Longitude" class="form-control" type="number" step="0.0001" />
                        <span asp-validation-for="Longitude" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        💾 Сохранить изменения
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        ← Отмена
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
