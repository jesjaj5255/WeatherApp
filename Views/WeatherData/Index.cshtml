@model IEnumerable<WeatherApp.Models.WeatherData>

@{
    ViewData["Title"] = "Weather Records";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>🌡️ Weather Records</h2>
    <div class="d-flex gap-2 align-items-center">
        <small class="text-muted">Global visits: <span class="badge bg-secondary">@ViewBag.GlobalVisits</span></small>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-success btn-sm">➕ Add Record</a>
        }
    </div>
</div>

<form method="get" class="row g-2 mb-4">
    <div class="col-md-4">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search by city or description..." />
    </div>
    <div class="col-md-3">
        <select name="cityId" asp-items="@ViewBag.Cities" class="form-select">
            <option value="">-- All Cities --</option>
        </select>
    </div>
    <div class="col-md-3">
        <input type="date" name="date" value="@ViewBag.Date" class="form-control" />
    </div>
    <div class="col-md-2 d-flex gap-1">
        <button type="submit" class="btn btn-primary flex-fill">Filter</button>
        <a asp-action="Index" class="btn btn-outline-secondary">✕</a>
    </div>
</form>

<div class="mb-2 d-flex gap-2">
    <span class="small text-muted">View:</span>
    <a asp-action="Index" asp-route-search="@ViewBag.Search" asp-route-cityId="@ViewBag.CityId"
       asp-route-date="@ViewBag.Date" asp-route-viewMode="table"
       class="btn btn-sm @(ViewBag.ViewMode == "table" ? "btn-dark" : "btn-outline-dark")">Table</a>
    <a asp-action="Index" asp-route-search="@ViewBag.Search" asp-route-cityId="@ViewBag.CityId"
       asp-route-date="@ViewBag.Date" asp-route-viewMode="cards"
       class="btn btn-sm @(ViewBag.ViewMode == "cards" ? "btn-dark" : "btn-outline-dark")">Cards</a>
</div>

@if (ViewBag.ViewMode == "cards")
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100">
                    <div class="card-header">
                        <strong>📍 @item.City?.Name</strong>
                        <span class="float-end text-muted small">@item.Date.ToString("dd.MM.yyyy")</span>
                    </div>
                    <div class="card-body">
                        <p>🌡️ <strong>@item.Temperature°C</strong> | 💧 @item.Humidity% | 💨 @item.WindSpeed km/h</p>
                        <p class="text-muted">@item.Description</p>
                    </div>
                    <div class="card-footer d-flex gap-1">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>City</th>
                    <th>Temp (°C)</th>
                    <th>Humidity (%)</th>
                    <th>Wind (km/h)</th>
                    <th>Description</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.City?.Name</td>
                        <td><span class="badge bg-info">@item.Temperature</span></td>
                        <td><span class="badge bg-primary">@item.Humidity</span></td>
                        <td>@item.WindSpeed</td>
                        <td>@item.Description</td>
                        <td>@item.Date.ToString("dd.MM.yyyy")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">No weather records found. <a asp-action="Index">Clear filters</a></div>
}
