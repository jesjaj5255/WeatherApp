@model WeatherApp.Models.WeatherData
@{
    ViewData["Title"] = "Добавить данные о погоде";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <h1 class="page-title">➕ Добавить данные о погоде</h1>

        <div class="form-card">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="CityId" class="form-label">🏙️ Город</label>
                    <select asp-for="CityId" class="form-select" asp-items="ViewBag.CityId">
                        <option value="">-- Выберите город --</option>
                    </select>
                    <span asp-validation-for="CityId" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Temperature" class="form-label"></label>
                    <div class="input-group">
                        <input asp-for="Temperature" class="form-control" type="number" step="0.1"
                               placeholder="-50 до 60" />
                        <span class="input-group-text">°C</span>
                    </div>
                    <span asp-validation-for="Temperature" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Humidity" class="form-label"></label>
                    <div class="input-group">
                        <input asp-for="Humidity" class="form-control" type="number" min="0" max="100"
                               placeholder="0 до 100" />
                        <span class="input-group-text">%</span>
                    </div>
                    <span asp-validation-for="Humidity" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="WindSpeed" class="form-label"></label>
                    <div class="input-group">
                        <input asp-for="WindSpeed" class="form-control" type="number" step="0.1" min="0" max="100"
                               placeholder="0 до 100" />
                        <span class="input-group-text">км/ч</span>
                    </div>
                    <span asp-validation-for="WindSpeed" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"
                              placeholder="Например: Ясно, небольшой ветер"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">💾 Сохранить</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">← Отмена</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
