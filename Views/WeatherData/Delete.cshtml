@model WeatherApp.Models.WeatherData

@{
    ViewData["Title"] = "Delete Weather Record";
}

<h2>🗑️ Delete Weather Record</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <div class="alert alert-danger">
            <h4>⚠️ Confirm Deletion</h4>
            <p>Are you sure you want to delete this weather record?</p>
        </div>
        <dl class="row">
            <dt class="col-sm-4">City</dt>
            <dd class="col-sm-8">@Model.City?.Name</dd>
            <dt class="col-sm-4">Date</dt>
            <dd class="col-sm-8">@Model.Date.ToString("dd.MM.yyyy HH:mm")</dd>
            <dt class="col-sm-4">Temperature</dt>
            <dd class="col-sm-8">@Model.Temperature°C</dd>
            <dt class="col-sm-4">Description</dt>
            <dd class="col-sm-8">@Model.Description</dd>
        </dl>
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
