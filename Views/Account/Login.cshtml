@model LoginViewModel

@{
    ViewData["Title"] = "Вход";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h2>Вход в систему</h2>
        <form method="post" class="mt-4">
            <div class="mb-3">
                <label for="Email" class="form-label">Email</label>
                <input type="email" class="form-control" id="Email" asp-for="Email" required>
                <span class="text-danger" asp-validation-for="Email"></span>
            </div>

            <div class="mb-3">
                <label for="Password" class="form-label">Пароль</label>
                <input type="password" class="form-control" id="Password" asp-for="Password" required>
                <span class="text-danger" asp-validation-for="Password"></span>
            </div>

            <div class="mb-3 form-check">
                <input type="checkbox" class="form-check-input" id="RememberMe" asp-for="RememberMe">
                <label class="form-check-label" for="RememberMe">Запомнить меня</label>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div class="alert alert-danger">@error.ErrorMessage</div>
                }
            }

            <button type="submit" class="btn btn-primary w-100">Войти</button>
        </form>

        <p class="mt-3">
            Нет аккаунта? <a href="/Account/Register">Зарегистрируйтесь</a>
        </p>

        <div class="alert alert-info mt-3">
            <strong>Demo admin account:</strong><br>
            Email: admin@weatherapp.com<br>
            Password: Admin@123
        </div>
    </div>
</div>