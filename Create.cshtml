@model WeatherData

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h2>Добавить запись о погоде</h2>
            <hr>

            <form asp-controller="WeatherData" asp-action="Create" method="post">
                <div class="form-group mb-3">
                    <label asp-for="CityId" class="form-label"></label>
                    <select asp-for="CityId" asp-items="ViewBag.CityId" class="form-control">
                        <option value="">-- Выберите город --</option>
                    </select>
                    <span asp-validation-for="CityId" class="text-danger small"></span>
                </div>

                <div class="form-row mb-3">
                    <div class="col-md-6">
                        <label asp-for="Temperature" class="form-label"></label>
                        <input asp-for="Temperature" class="form-control" placeholder="Температура" step="0.1">
                        <span asp-validation-for="Temperature" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Humidity" class="form-label"></label>
                        <input asp-for="Humidity" class="form-control" placeholder="Влажность" type="number">
                        <span asp-validation-for="Humidity" class="text-danger small"></span>
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="WindSpeed" class="form-label"></label>
                    <input asp-for="WindSpeed" class="form-control" placeholder="Скорость ветра" step="0.1">
                    <span asp-validation-for="WindSpeed" class="text-danger small"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Описание"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-primary">Сохранить</button>
                    <a asp-controller="WeatherData" asp-action="Index" class="btn btn-secondary">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</div>